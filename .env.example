# ─────────────────────────────────────────────────────────────────────────────
# starkzap-rs environment configuration
# Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core wallet (required for most examples) ──────────────────────────────────

# Your Starknet account's private key (0x-prefixed hex felt)
PRIVATE_KEY=0x...

# Your deployed Starknet account address (ArgentX, Braavos, OpenZeppelin)
ACCOUNT_ADDRESS=0x...

# A recipient address for transfer examples
RECIPIENT_ADDRESS=0x...

# ── RPC provider ──────────────────────────────────────────────────────────────
#
# Optional — if not set, the SDK falls back to public BlastAPI endpoints.
# Public endpoints work but have rate limits. For production, use your own key.
#
# Alchemy (recommended):
#   Mainnet: https://starknet-mainnet.g.alchemy.com/starknet/version/rpc/v0_8/YOUR_KEY
#   Sepolia: https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_8/YOUR_KEY
#
# Infura:
#   Mainnet: https://starknet-mainnet.infura.io/v3/YOUR_KEY
#
# Blast (public fallback, no key needed):
#   Mainnet: https://starknet-mainnet.public.blastapi.io/rpc/v0_8
#   Sepolia: https://starknet-sepolia.public.blastapi.io/rpc/v0_8
#
# Devnet (local starknet-devnet):
#   http://127.0.0.1:5050/rpc

# RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_8/YOUR_KEY

# ── AVNU Paymaster (optional) ─────────────────────────────────────────────────
#
# Required for mainnet gasless transactions.
# Obtain at: https://app.avnu.fi
# Not required for Sepolia — paymaster works without a key on testnet.

# AVNU_API_KEY=your_avnu_api_key

# ── Privy (feature = "privy") ─────────────────────────────────────────────────
#
# Obtain from: https://privy.io → Dashboard → Settings → API Keys

# PRIVY_APP_ID=clxxxxxxxxxxxxxxxx
# PRIVY_APP_SECRET=privy_secret_...

# ── Cartridge (feature = "cartridge") ────────────────────────────────────────
#
# These are issued by the Cartridge Controller browser flow.
# In production, your frontend sends these to your backend API after auth.

# CARTRIDGE_SESSION_BUNDLE_B64=...
# CARTRIDGE_ACCOUNT_ADDRESS=0x...

# ── Integration tests ─────────────────────────────────────────────────────────

# TEST_PRIVATE_KEY=0x...
# TEST_ACCOUNT_ADDRESS=0x...
# TEST_RECIPIENT_ADDRESS=0x...
# TEST_RPC_URL=http://127.0.0.1:5050/rpc
